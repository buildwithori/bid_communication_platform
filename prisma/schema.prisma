generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  entrepreneur
  admin
  trainer
}

enum UserStatus {
  pending
  active
  inactive
}

enum AuthProvider {
  google
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum CalendarProvider {
  google
}

enum CalendarConnectionStatus {
  connected
  error
  revoked
}

enum BusinessStatus {
  active
  inactive
  archived
}

enum BusinessSource {
  self_registered
  admin_invited
}

enum BusinessRelationship {
  owner
  representative
}

enum TrainerRoleLabel {
  mentor
  trainer
  guest_expert
  investment_analyst
}

enum TrainerAccessLevel {
  full
  guest
}

enum TrainerCapabilityStatus {
  active
  inactive
}

enum ProgrammeAccessType {
  free
  assigned
}

enum ContentItemType {
  video
  pdf
  tool
}

enum ContentItemStatus {
  draft
  processing
  ready
  failed
  archived
}

enum AssetStatus {
  pending
  processing
  ready
  failed
  archived
}

enum FileAssetUsage {
  deliverable_submission
  content_pdf
  tool_pdf
  report_export
}

enum ReportExportFormat {
  csv
  xlsx
}

enum ReportExportStatus {
  queued
  processing
  ready
  failed
}

enum ToolLinkSource {
  library
  custom
}

enum EntrepreneurToolType {
  pdf
  embedded_tool
}

enum EntrepreneurToolVisibility {
  all_entrepreneurs
  programmes
  entrepreneurs
}

enum EntrepreneurToolStatus {
  draft
  published
  archived
}

enum ToolRequestStatus {
  under_review
  in_development
  built
  declined
}

enum SessionType {
  mentor_checkin
  office_hours
  investor_prep
}

enum SessionStatus {
  requested
  confirmed
  declined
  cancelled
  completed
}

enum SessionSource {
  entrepreneur_request
  team_created
}

enum SessionTargetType {
  open_team
  specific_user
}

enum SessionNoteVisibility {
  internal
  participant
}

enum NotificationType {
  session_request
  session_confirmed
  session_rescheduled
  session_declined
  session_cancelled
  session_completed
  deliverable_review
  deliverable_changes_requested
  tool_request_updated
  trainer_nudge
  system
}

enum NotificationSeverity {
  info
  success
  warning
  critical
}

enum NotificationEntityType {
  session
  deliverable_instance
  tool_request
  programme
  entrepreneur
  content_item
}

enum NotificationChannel {
  in_app
  email
}

enum NotificationDeliveryStatus {
  pending
  processing
  sent
  failed
  skipped
}

enum AuditOutboxStatus {
  pending
  processing
  processed
  failed
}

enum LearnerProgressStatus {
  not_started
  in_progress
  completed
}

enum ProgressSource {
  player
  explicit_action
  system
}

enum DeliverableDueType {
  fixed_date
  module_completion
  recurring
}

enum DeliverableRecurringCadence {
  monthly
  quarterly
  six_monthly
}

enum DeliverableRequiredScope {
  all
  stage
}

enum DeliverableInstanceStatus {
  not_submitted
  submitted
  changes_required
  approved
  overdue
}

enum DeliverableReviewDecision {
  approved
  changes_required
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String?    @map("password_hash")
  firstName       String?    @map("first_name")
  lastName        String?    @map("last_name")
  phone           String?
  avatarUrl       String?    @map("avatar_url")
  role            UserRole
  status          UserStatus @default(pending)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  invitedById     String?    @map("invited_by_id")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  invitedBy                   User?                      @relation("UserInvitations", fields: [invitedById], references: [id])
  invitedUsers                User[]                     @relation("UserInvitations")
  sentInvitations             Invitation[]               @relation("InvitationInvitedBy")
  calendarConnections         CalendarConnection[]
  oauthAccounts               OAuthAccount[]
  refreshTokens               RefreshToken[]
  emailVerificationTokens     EmailVerificationToken[]
  passwordResetTokens         PasswordResetToken[]
  businessMemberships         BusinessMembership[]
  trainerCapability           TrainerCapability?
  trainerSpecialisms          TrainerSpecialism[]
  publishedProgrammes         Programme[]                @relation("ProgrammePublishedBy")
  archivedProgrammes          Programme[]                @relation("ProgrammeArchivedBy")
  grantedProgrammeAccess      ProgrammeAccessGrant[]     @relation("ProgrammeAccessGrantedBy")
  entrepreneurProgrammeGrants ProgrammeAccessGrant[]     @relation("ProgrammeAccessEntrepreneur")
  ownedContentItems           ContentItem[]              @relation("ContentTrainer")
  contentRatings              ContentRating[]            @relation("ContentRatingEntrepreneur")
  trainerContentRatings       ContentRating[]            @relation("ContentRatingTrainer")
  createdTools                Tool[]                     @relation("ToolCreatedBy")
  updatedTools                Tool[]                     @relation("ToolUpdatedBy")
  toolAccess                  ToolEntrepreneurAccess[]   @relation("ToolAccessEntrepreneur")
  grantedToolAccess           ToolEntrepreneurAccess[]   @relation("ToolAccessGrantedBy")
  hiddenTools                 ToolHiddenEntrepreneur[]   @relation("ToolHiddenEntrepreneur")
  hiddenToolOverrides         ToolHiddenEntrepreneur[]   @relation("ToolHiddenBy")
  toolRequests                ToolRequest[]              @relation("ToolRequestEntrepreneur")
  decidedToolRequests         ToolRequest[]              @relation("ToolRequestDecidedBy")
  programmeGoals              ProgrammeGoal[]            @relation("ProgrammeGoalEntrepreneur")
  fundraisingRounds           FundraisingRound[]         @relation("FundraisingRoundEntrepreneur")
  periodicUpdates             PeriodicUpdate[]           @relation("PeriodicUpdateEntrepreneur")
  deliverableInstances        DeliverableInstance[]      @relation("DeliverableInstanceEntrepreneur")
  deliverableSubmissions      DeliverableSubmission[]    @relation("DeliverableSubmissionSubmittedBy")
  deliverableReviews          DeliverableReview[]        @relation("DeliverableReviewReviewer")
  updatedDeliverableDueDates  DeliverableInstance[]      @relation("DeliverableDueDateUpdatedBy")
  requestedSessions           Session[]                  @relation("SessionEntrepreneur")
  ownedSessions               Session[]                  @relation("SessionOwner")
  targetedSessions            Session[]                  @relation("SessionTarget")
  createdSessions             Session[]                  @relation("SessionCreatedBy")
  sessionNotes                SessionNote[]              @relation("SessionNoteAuthor")
  sessionReschedules          SessionReschedule[]        @relation("SessionRescheduleActor")
  declinedSessionRequests     SessionRequestDecline[]    @relation("SessionRequestDeclineUser")
  receivedNotifications       Notification[]             @relation("NotificationRecipient")
  actedNotifications          Notification[]             @relation("NotificationActor")
  notificationPreferences     NotificationPreference[]
  auditLogs                   AuditLog[]                 @relation("AuditLogActor")
  auditOutboxEvents           AuditOutbox[]              @relation("AuditOutboxActor")
  contentProgress             LearnerContentProgress[]   @relation("LearnerContentProgressEntrepreneur")
  moduleProgress              LearnerModuleProgress[]    @relation("LearnerModuleProgressEntrepreneur")
  programmeProgress           LearnerProgrammeProgress[] @relation("LearnerProgrammeProgressEntrepreneur")
  uploadedFiles               FileAsset[]                @relation("FileAssetUploadedBy")
  uploadedVideos              VideoAsset[]               @relation("VideoAssetUploadedBy")
  requestedReportExports      ReportExport[]             @relation("ReportExportRequestedBy")

  @@index([role, status])
  @@index([invitedById])
  @@map("users")
}

model OAuthAccount {
  id                String       @id @default(cuid())
  userId            String       @map("user_id")
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id")
  email             String
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
  @@map("oauth_accounts")
}

model RefreshToken {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  tokenHash     String    @unique @map("token_hash")
  userAgent     String?   @map("user_agent")
  ipAddress     String?   @map("ip_address")
  expiresAt     DateTime  @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, consumedAt])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, consumedAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Invitation {
  id          String           @id @default(cuid())
  email       String
  role        UserRole
  tokenHash   String           @unique @map("token_hash")
  invitedById String           @map("invited_by_id")
  status      InvitationStatus @default(pending)
  expiresAt   DateTime         @map("expires_at")
  acceptedAt  DateTime?        @map("accepted_at")
  revokedAt   DateTime?        @map("revoked_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  invitedBy User @relation("InvitationInvitedBy", fields: [invitedById], references: [id])

  @@index([email, status])
  @@index([role, status])
  @@index([invitedById])
  @@map("invitations")
}

model CalendarConnection {
  id                    String                   @id @default(cuid())
  userId                String                   @map("user_id")
  provider              CalendarProvider
  providerAccountEmail  String                   @map("provider_account_email")
  encryptedAccessToken  String                   @map("encrypted_access_token")
  encryptedRefreshToken String                   @map("encrypted_refresh_token")
  scopes                String[]
  status                CalendarConnectionStatus @default(connected)
  lastSyncedAt          DateTime?                @map("last_synced_at")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([provider, status])
  @@map("calendar_connections")
}

model CompanySettings {
  id                                    String   @id @default(cuid())
  singletonKey                          String   @unique @default("default") @map("singleton_key")
  periodicUpdateOverdueAfterDays        Int      @default(30) @map("periodic_update_overdue_after_days")
  moduleCompletionDeliverableDueDays    Int?     @map("module_completion_deliverable_due_days")
  defaultCurrency                       String   @default("USD") @map("default_currency")
  defaultTimezone                       String   @default("UTC") @map("default_timezone")
  defaultSessionProvider                String   @default("google_meet") @map("default_session_provider")
  sessionWorkingDays                    Int[]    @default([1, 2, 3, 4, 5]) @map("session_working_days")
  sessionWorkdayStartMinutes            Int      @default(540) @map("session_workday_start_minutes")
  sessionWorkdayEndMinutes              Int      @default(1020) @map("session_workday_end_minutes")
  sessionSlotIntervalMinutes            Int      @default(30) @map("session_slot_interval_minutes")
  defaultSessionDurationMinutes         Int      @default(60) @map("default_session_duration_minutes")
  inAppNotificationsEnabledByDefault    Boolean  @default(true) @map("in_app_notifications_enabled_by_default")
  emailNotificationsEnabledByDefault    Boolean  @default(true) @map("email_notifications_enabled_by_default")
  reminderNotificationsEnabledByDefault Boolean  @default(true) @map("reminder_notifications_enabled_by_default")
  weeklyDigestEnabledByDefault          Boolean  @default(false) @map("weekly_digest_enabled_by_default")
  createdAt                             DateTime @default(now()) @map("created_at")
  updatedAt                             DateTime @updatedAt @map("updated_at")

  @@map("company_settings")
}

model Sector {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  businesses         Business[]
  trainerSpecialisms TrainerSpecialism[]

  @@index([active])
  @@map("sectors")
}

model BusinessStage {
  id         String   @id @default(cuid())
  name       String
  key        String   @unique
  definition String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  businesses       Business[]
  deliverableRules ProgrammeDeliverableRule[]

  @@index([active])
  @@map("business_stages")
}

model ProgrammeGoalType {
  id                   String   @id @default(cuid())
  name                 String
  key                  String   @unique
  description          String?
  requiresTargetAmount Boolean  @default(false) @map("requires_target_amount")
  active               Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  programmeGoals ProgrammeGoal[]

  @@index([active])
  @@map("programme_goal_types")
}

model ToolArea {
  id           String        @id @default(cuid())
  name         String
  key          String        @unique
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  tools        Tool[]
  toolRequests ToolRequest[]

  @@index([active])
  @@map("tool_areas")
}

model Business {
  id                    String         @id @default(cuid())
  name                  String
  country               String
  sectorId              String?        @map("sector_id")
  stageId               String?        @map("stage_id")
  onboardingCompletedAt DateTime?      @map("onboarding_completed_at")
  status                BusinessStatus @default(active)
  source                BusinessSource @default(self_registered)
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  sector      Sector?              @relation(fields: [sectorId], references: [id])
  stage       BusinessStage?       @relation(fields: [stageId], references: [id])
  memberships BusinessMembership[]

  @@index([sectorId])
  @@index([stageId])
  @@index([status, source])
  @@map("businesses")
}

model BusinessMembership {
  id           String               @id @default(cuid())
  userId       String               @map("user_id")
  businessId   String               @map("business_id")
  relationship BusinessRelationship @default(representative)
  isPrimary    Boolean              @default(true) @map("is_primary")
  joinedAt     DateTime             @default(now()) @map("joined_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@unique([userId, businessId])
  @@index([businessId])
  @@index([userId, isPrimary])
  @@index([joinedAt, id])
  @@map("business_memberships")
}

model TrainerCapability {
  id              String                  @id @default(cuid())
  userId          String                  @unique @map("user_id")
  roleLabel       TrainerRoleLabel        @default(trainer) @map("role_label")
  accessLevel     TrainerAccessLevel      @default(full) @map("access_level")
  accessExpiresOn DateTime?               @map("access_expires_on")
  status          TrainerCapabilityStatus @default(active)
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([status, accessLevel])
  @@map("trainer_capabilities")
}

model TrainerSpecialism {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  sectorId  String   @map("sector_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  sector Sector @relation(fields: [sectorId], references: [id])

  @@unique([userId, sectorId])
  @@index([sectorId])
  @@map("trainer_specialisms")
}

model Programme {
  id               String              @id @default(cuid())
  name             String
  description      String
  accessType       ProgrammeAccessType @map("access_type")
  startDate        DateTime            @map("start_date")
  endDate          DateTime            @map("end_date")
  maxEntrepreneurs Int                 @map("max_entrepreneurs")
  publishedAt      DateTime?           @map("published_at")
  publishedById    String?             @map("published_by_id")
  archivedAt       DateTime?           @map("archived_at")
  archivedById     String?             @map("archived_by_id")
  archiveReason    String?             @map("archive_reason")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  publishedBy          User?                      @relation("ProgrammePublishedBy", fields: [publishedById], references: [id])
  archivedBy           User?                      @relation("ProgrammeArchivedBy", fields: [archivedById], references: [id])
  modules              ProgrammeModule[]
  accessGrants         ProgrammeAccessGrant[]
  programmeGoals       ProgrammeGoal[]
  fundraisingRounds    FundraisingRound[]
  periodicUpdates      PeriodicUpdate[]
  reportExports        ReportExport[]
  contentProgress      LearnerContentProgress[]
  moduleProgress       LearnerModuleProgress[]
  progress             LearnerProgrammeProgress[]
  toolAccess           ToolProgrammeAccess[]
  deliverableRules     ProgrammeDeliverableRule[]
  deliverableInstances DeliverableInstance[]
  sessions             Session[]

  @@index([accessType])
  @@index([publishedAt, archivedAt])
  @@index([startDate, endDate])
  @@map("programmes")
}

model ProgrammeAccessGrant {
  id                 String    @id @default(cuid())
  programmeId        String    @map("programme_id")
  entrepreneurUserId String    @map("entrepreneur_user_id")
  grantedById        String    @map("granted_by_id")
  grantedAt          DateTime  @default(now()) @map("granted_at")
  revokedAt          DateTime? @map("revoked_at")
  revokeReason       String?   @map("revoke_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  programme    Programme @relation(fields: [programmeId], references: [id])
  entrepreneur User      @relation("ProgrammeAccessEntrepreneur", fields: [entrepreneurUserId], references: [id])
  grantedBy    User      @relation("ProgrammeAccessGrantedBy", fields: [grantedById], references: [id])

  @@unique([programmeId, entrepreneurUserId])
  @@index([entrepreneurUserId, revokedAt])
  @@index([programmeId, revokedAt])
  @@index([grantedById])
  @@map("programme_access_grants")
}

model ProgrammeGoal {
  id                 String   @id @default(cuid())
  entrepreneurUserId String   @map("entrepreneur_user_id")
  programmeId        String?  @map("programme_id")
  goalTypeId         String   @map("goal_type_id")
  targetAmountCents  Int?     @map("target_amount_cents")
  description        String?
  evidence           String?
  milestoneAchieved  Boolean  @default(false) @map("milestone_achieved")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  entrepreneur      User               @relation("ProgrammeGoalEntrepreneur", fields: [entrepreneurUserId], references: [id])
  programme         Programme?         @relation(fields: [programmeId], references: [id])
  goalType          ProgrammeGoalType  @relation(fields: [goalTypeId], references: [id])
  fundraisingRounds FundraisingRound[]

  @@index([entrepreneurUserId])
  @@index([programmeId])
  @@index([goalTypeId])
  @@map("programme_goals")
}

model FundraisingRound {
  id                 String   @id @default(cuid())
  entrepreneurUserId String   @map("entrepreneur_user_id")
  programmeId        String?  @map("programme_id")
  programmeGoalId    String?  @map("programme_goal_id")
  name               String
  amountCents        Int      @map("amount_cents")
  currency           String   @default("USD")
  source             String?
  date               DateTime
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  entrepreneur  User           @relation("FundraisingRoundEntrepreneur", fields: [entrepreneurUserId], references: [id])
  programme     Programme?     @relation(fields: [programmeId], references: [id])
  programmeGoal ProgrammeGoal? @relation(fields: [programmeGoalId], references: [id])

  @@index([entrepreneurUserId, date])
  @@index([currency, date])
  @@index([programmeId])
  @@index([programmeGoalId])
  @@map("fundraising_rounds")
}

model PeriodicUpdate {
  id                 String   @id @default(cuid())
  entrepreneurUserId String   @map("entrepreneur_user_id")
  programmeId        String?  @map("programme_id")
  periodStart        DateTime @map("period_start")
  periodEnd          DateTime @map("period_end")
  submittedAt        DateTime @default(now()) @map("submitted_at")
  jobsCreated        Int      @default(0) @map("jobs_created")
  jobsWomen          Int      @default(0) @map("jobs_women")
  jobsMen            Int      @default(0) @map("jobs_men")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  entrepreneur User       @relation("PeriodicUpdateEntrepreneur", fields: [entrepreneurUserId], references: [id])
  programme    Programme? @relation(fields: [programmeId], references: [id])

  @@index([entrepreneurUserId, periodEnd])
  @@index([entrepreneurUserId, submittedAt])
  @@index([programmeId])
  @@index([programmeId, periodStart, periodEnd])
  @@map("periodic_updates")
}

model ReportExport {
  id            String             @id @default(cuid())
  requestedById String             @map("requested_by_id")
  programmeId   String?            @map("programme_id")
  format        ReportExportFormat
  status        ReportExportStatus @default(queued)
  dateFrom      DateTime           @map("date_from")
  dateTo        DateTime           @map("date_to")
  fileAssetId   String?            @unique @map("file_asset_id")
  attemptCount  Int                @default(0) @map("attempt_count")
  failureReason String?            @map("failure_reason")
  startedAt     DateTime?          @map("started_at")
  completedAt   DateTime?          @map("completed_at")
  expiresAt     DateTime?          @map("expires_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  requestedBy User       @relation("ReportExportRequestedBy", fields: [requestedById], references: [id])
  programme   Programme? @relation(fields: [programmeId], references: [id])
  fileAsset   FileAsset? @relation(fields: [fileAssetId], references: [id])

  @@index([requestedById, createdAt])
  @@index([status, createdAt])
  @@index([programmeId])
  @@map("report_exports")
}

model LearningModule {
  id          String   @id @default(cuid())
  title       String
  description String
  isReusable  Boolean  @default(true) @map("is_reusable")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  programmes            ProgrammeModule[]
  contentItems          ModuleContentItem[]
  contentProgress       LearnerContentProgress[]
  progress              LearnerModuleProgress[]
  deliverableRulesAfter ProgrammeDeliverableRule[] @relation("DeliverableRuleDueAfterModule")

  @@map("modules")
}

model ProgrammeModule {
  id          String   @id @default(cuid())
  programmeId String   @map("programme_id")
  moduleId    String   @map("module_id")
  position    Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  programme Programme      @relation(fields: [programmeId], references: [id])
  module    LearningModule @relation(fields: [moduleId], references: [id])

  @@unique([programmeId, moduleId])
  @@unique([programmeId, position])
  @@index([moduleId])
  @@map("programme_modules")
}

model ContentItem {
  id              String            @id @default(cuid())
  title           String
  type            ContentItemType
  trainerId       String?           @map("trainer_id")
  durationSeconds Int?              @map("duration_seconds")
  status          ContentItemStatus @default(draft)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

