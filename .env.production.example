# Copy this file to .env on the production host. Replace every CHANGE_ME value.
# Never commit the resulting .env file.

# Container images. Pin immutable tags for releases when using a registry.
API_IMAGE=bid-hub-api:latest
WEB_IMAGE=bid-hub-web:latest

# PostgreSQL and Redis
POSTGRES_DB=bid_hub
POSTGRES_USER=bid
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
# URL-encode POSTGRES_PASSWORD before placing it in DATABASE_URL.
DATABASE_URL=postgresql://bid:CHANGE_ME_URL_ENCODED_DATABASE_PASSWORD@postgres:5432/bid_hub?schema=public
REDIS_URL=redis://redis:6379
PORT=4000

# Public application origin
# Production uses one HTTPS origin: Caddy sends /api/* to NestJS and all other
# traffic to Next.js.
APP_WEB_URL=https://hub.example.org
WEB_ORIGIN=https://hub.example.org
API_PUBLIC_URL=https://hub.example.org
NEXT_PUBLIC_API_BASE_URL=https://hub.example.org/api

# Background jobs
AUDIT_PROCESS_INTERVAL_MS=5000
NOTIFICATION_DELIVERY_INTERVAL_MS=5000
NOTIFICATION_AUTOMATION_INTERVAL_MS=900000
DELIVERABLE_RECURRENCE_INTERVAL_MS=900000

# Transactional email (the sender must be verified in Resend)
EMAIL_TRANSPORT=resend
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
MAIL_FROM="BID Hub <no-reply@example.org>"

# Google authentication and Calendar
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://hub.example.org/api/auth/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://hub.example.org/api/calendar/google/callback
# Generate with: openssl rand -base64 32
CALENDAR_TOKEN_ENCRYPTION_KEY=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS

# DigitalOcean Spaces (private bucket)
DO_SPACES_BUCKET=CHANGE_ME_PRIVATE_BUCKET_NAME
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_ACCESS_KEY_ID=CHANGE_ME_SPACES_ACCESS_KEY
DO_SPACES_SECRET_ACCESS_KEY=CHANGE_ME_SPACES_SECRET_KEY
DO_SPACES_FORCE_PATH_STYLE=false
# Do not set DO_SPACES_INTERNAL_ENDPOINT in production.

# Mux video
MUX_TOKEN_ID=CHANGE_ME_MUX_TOKEN_ID
MUX_TOKEN_SECRET=CHANGE_ME_MUX_TOKEN_SECRET
MUX_WEBHOOK_SECRET=CHANGE_ME_MUX_WEBHOOK_SIGNING_SECRET
MUX_SIGNING_KEY_ID=CHANGE_ME_MUX_SIGNING_KEY_ID
# The API expects the PEM private key encoded as one base64 string.
# Generate it with: base64 -w 0 mux-private-key.pem
MUX_SIGNING_PRIVATE_KEY=CHANGE_ME_BASE64_ENCODED_MUX_PRIVATE_KEY

# One-time production bootstrap
# These values create the first administrator only when production-bootstrap-v1
# has not completed. After the first successful deployment, remove the password.
PRODUCTION_ADMIN_EMAIL=admin@example.org
PRODUCTION_ADMIN_FIRST_NAME=CHANGE_ME_FIRST_NAME
PRODUCTION_ADMIN_LAST_NAME=CHANGE_ME_LAST_NAME
PRODUCTION_ADMIN_PHONE=
PRODUCTION_ADMIN_INITIAL_PASSWORD=CHANGE_ME_RANDOM_16_PLUS_CHARACTER_PASSWORD
