{
  "name": "bid-hub",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace @bid/web run dev",
    "dev:api": "npm --workspace @bid/api run start:dev",
    "email:dev": "npm --workspace @bid/api run email:dev",
    "build": "npm run build:shared && npm run build:web && npm run build:api",
    "build:web": "npm --workspace @bid/web run build",
    "build:api": "npm --workspace @bid/api run build",
    "build:shared": "npm --workspace @bid/shared run build",
    "start:web": "npm --workspace @bid/web run start",
    "start:api": "npm --workspace @bid/api run start",
    "lint": "npm --workspace @bid/web run lint",
    "test:api": "npm --workspace @bid/api run test",
    "check": "npm run lint && npm run typecheck && npm run test:api",
    "typecheck": "npm run typecheck:shared && npm run typecheck:web && npm run typecheck:api",
    "typecheck:web": "npm --workspace @bid/web run typecheck",
    "typecheck:api": "npm --workspace @bid/api run typecheck",
    "typecheck:shared": "npm --workspace @bid/shared run typecheck",
    "prisma:generate": "prisma generate",
    "prisma:validate": "dotenv -e .env.local -- prisma validate",
    "prisma:status": "dotenv -e .env.local -- sh -c 'DATABASE_URL=\"$DATABASE_HOST_URL\" prisma migrate status'",
    "prisma:migrate": "dotenv -e .env.local -- sh -c 'DATABASE_URL=\"$DATABASE_HOST_URL\" prisma migrate dev'",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:bootstrap:production": "node prisma/seed-production.js",
    "prisma:seed": "dotenv -e .env.local -- sh -c 'DATABASE_URL=\"$DATABASE_HOST_URL\" prisma db seed'",
    "prisma:studio": "dotenv -e .env.local -- sh -c 'DATABASE_URL=\"$DATABASE_HOST_URL\" prisma studio'",
    "docker:dev": "docker compose --env-file .env.local up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build -d",
    "dev:worker": "npm --workspace @bid/api run start:worker:dev",
    "start:worker": "npm --workspace @bid/api run start:worker"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "typescript": "5.2.2"
  },
  "overrides": {
    "@babel/runtime": "7.28.4",
    "brace-expansion@1.1.11": "1.1.13",
    "exceljs": {
      "uuid": "11.1.1"
    },
    "next": {
      "postcss": "8.5.19"
    }
  }
}
